# Keycloak Configuration — same realm and client as the SPA.
# Access is gated on the realm role below, not on a separate client.
VITE_KEYCLOAK_URL=http://localhost:8554
VITE_KEYCLOAK_REALM=quarkus
VITE_KEYCLOAK_CLIENT_ID=quarkus-app

# Realm role required to enter the admin app. Defaults to `admin` if unset.
VITE_ADMIN_REALM_ROLE=admin
